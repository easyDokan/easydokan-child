{
    "name": "easydokan-child",
    "version": "1.0.0",
    "main": "index.js",
    "scripts": {
        "build:scss": "sass assets/front/scss/main.scss assets/front/css/main.min.css --style compressed --no-source-map",
        "dev:scss": "sass assets/front/scss/main.scss assets/front/css/main.min.css --watch --style compressed",
        "build": "npm run build:scss",
        "zip": "npm run build && zip -r easydokan-child.zip . -x \"node_modules/*\" \"node_modules\" \".git/*\" \".git\" \"*.zip\" \"package-lock.json\" \"package.json\" \".gitignore\""
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/easyDokan/easydokan-child.git"
    },
    "keywords": [],
