    "type": "commonjs",
    "bugs": {
        "url": "https://github.com/easyDokan/easydokan-child/issues"
    },
    "homepage": "https://github.com/easyDokan/easydokan-child#readme",
    "description": "",
    "devDependencies": {
        "sass": "^1.99.0"
    }
}
